# ===========================================================================
# Task Manager — Production environment variables
# Salin file ini ke `.env` di VM produksi, isi nilainya, lalu jalankan
# `docker compose up -d --build`.
#
# JANGAN commit `.env` ke git.
# ===========================================================================

# ====== Domain & URL ======
# Domain publik tempat aplikasi diakses (yang ditangani Cloudflare Tunnel).
# Pastikan keduanya pakai HTTPS dan persis sama dengan yang Anda set di
# Cloudflare Dashboard (Public Hostname tunnel).
APP_URL=https://taskmanager.contoh.com
API_URL=https://taskmanager.contoh.com

# ====== Backend ======
# Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-panjang
SESSION_COOKIE_NAME=tm_session

# ====== Database (MySQL) ======
# Password kuat untuk root dan user aplikasi.
MYSQL_ROOT_PASSWORD=ganti-password-root-yang-kuat
MYSQL_DATABASE=taskmanager
MYSQL_USER=tmuser
MYSQL_PASSWORD=ganti-password-aplikasi

# Pakai service name "mysql" karena container backend connect via Docker network.
DATABASE_URL=mysql://tmuser:ganti-password-aplikasi@mysql:3306/taskmanager

# ====== Google OAuth ======
# Buat OAuth Client di Google Cloud Console (tipe Web).
# Authorized redirect URI harus tepat sama dengan GOOGLE_REDIRECT_URI di bawah.
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=https://taskmanager.contoh.com/api/auth/google/callback

GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.events

# ====== Web Push (VAPID) ======
# Generate sekali saja, simpan baik-baik.
# Generate dengan:
#   docker run --rm node:20-alpine npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@contoh.com

# ====== Cloudflare Tunnel ======
# Token tunnel (bukan secret, tapi bersifat private). Ambil dari
# Cloudflare Zero Trust Dashboard saat membuat tunnel baru:
#   Networks → Tunnels → Create a tunnel → Cloudflared → Copy token.
CLOUDFLARE_TUNNEL_TOKEN=
